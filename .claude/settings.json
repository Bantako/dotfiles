{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | grep -q '\\.nix$' && (cd \"$CLAUDE_PROJECT_DIR\" && nix flake check --no-build 2>&1 | tail -30) || true",
            "timeout": 60,
            "statusMessage": "nix flake check..."
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(nix flake check *)",
      "Bash(nh os switch --dry *)",
      "mcp__todoist__todoist_tasks"
    ]
  }
}
