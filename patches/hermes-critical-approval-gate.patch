+# Critical tier: irreversible data destruction. Unlike DANGEROUS_PATTERNS a
+# match here can never be satisfied by yolo mode, the permanent allowlist,
+# session-scoped approval caching, or smart (LLM) approval — every occurrence
+# requires a fresh human decision. Rationale: a session approval granted for
+# `docker compose down -v` on one stack silently approved the same verb on a
+# different stack and destroyed its volumes before a backup dump had been
+# taken (wger incident, 2026-07-08).
+CRITICAL_PATTERNS = [
+    (r'\bdocker(?:-compose|\s+compose)\b[^\n;|&]*\bdown\b[^\n;|&]*(?:\s-v\b|\s--volumes\b)',
+     "docker compose down with volume deletion (-v/--volumes)"),
+    (r'\bdocker\s+volume\s+(?:rm|remove|prune)\b', "docker volume rm/prune"),
+    (r'\bdocker\s+system\s+prune\b', "docker system prune"),
+    (r'\brestic\b[^\n;|&]*\b(?:forget|prune)\b',
+     "restic forget/prune (backup snapshot deletion)"),
+    (r'\bb2(?:v[0-9]+)?\b[^\n;|&]*\bdelete',
+     "b2 delete operation (cloud backup deletion)"),
+    (r'\bdrop\s+database\b', "SQL DROP DATABASE"),
+]
+CRITICAL_PATTERNS_COMPILED = [
+    (re.compile(pattern, _RE_FLAGS), description)
+    for pattern, description in CRITICAL_PATTERNS
+]
+
+
+def detect_critical_command(command: str) -> tuple:
+    """Detect irreversible data-destroying commands (critical tier)."""
+    normalized = _normalize_command_for_detection(command)
+    for compiled, description in CRITICAL_PATTERNS_COMPILED:
+        if compiled.search(normalized):
+            return True, description
+    return False, ""
+
+
