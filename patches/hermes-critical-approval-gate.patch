+def _require_critical_approval(command: str, description: str,
+                               approval_callback=None) -> dict:
+    """Force a fresh, uncached human decision for a critical command.
+
+    Runs before the yolo / allowlist / session-approval bypasses. Any
+    approving choice is valid for this single invocation only ("once"
+    semantics regardless of what the UI offered), and nothing is persisted.
+    With no human approval surface available the command is denied.
+    """
+    session_key = get_current_session_key()
+    is_cli = _is_interactive_cli()
+    is_gateway = _is_gateway_approval_context()
+    is_ask = env_var_enabled("HERMES_EXEC_ASK")
+
+    denied_msg = (
+        f"BLOCKED: Critical destructive command ({description}). The user "
+        "has NOT consented to this action. Do NOT retry this command, do "
+        "NOT rephrase it, and do NOT attempt the same outcome via a "
+        "different command. Explain to the user what you wanted to run and "
+        "why, then wait for their instruction."
+    )
+    no_surface_msg = (
+        f"BLOCKED: Critical destructive command ({description}) requires "
+        "explicit human approval for every single invocation, and no "
+        "approval surface is available in this context. Do NOT retry and "
+        "do NOT attempt the same outcome via a different command."
+    )
+
+    if is_gateway or is_ask:
+        with _lock:
+            notify_cb = _gateway_notify_cbs.get(session_key)
+        if notify_cb is None:
+            logger.warning("Critical command denied (no gateway notify): %s",
+                           command[:200])
+            return {"approved": False, "message": no_surface_msg,
+                    "description": description}
+        approval_data = {
+            "command": command,
+            "pattern_key": f"critical:{description}",
+            "pattern_keys": [f"critical:{description}"],
+            "description": f"CRITICAL (approval never cached): {description}",
+            "allow_permanent": False,
+        }
+        decision = _await_gateway_decision(session_key, notify_cb,
+                                           approval_data, surface="gateway")
+        if decision.get("resolved") and decision.get("choice") in {
+                "once", "session", "always"}:
+            # Deliberately no approve_session / approve_permanent here:
+            # critical approvals never outlive the single command.
+            return {"approved": True, "message": None, "user_approved": True,
+                    "description": description}
+        return {"approved": False, "message": denied_msg,
+                "description": description, "user_consent": False}
+
+    if is_cli:
+        choice = prompt_dangerous_approval(
+            command, f"CRITICAL (approval never cached): {description}",
+            allow_permanent=False, approval_callback=approval_callback)
+        if choice in {"once", "session", "always"}:
+            # Same as above: no persistence, even if the UI offered it.
+            return {"approved": True, "message": None, "user_approved": True,
+                    "description": description}
+        return {"approved": False, "message": denied_msg,
+                "description": description, "user_consent": False}
+
+    # Non-interactive, non-gateway (cron, batch): fail closed.
+    logger.warning("Critical command denied in non-interactive context: %s",
+                   command[:200])
+    return {"approved": False, "message": no_surface_msg,
+            "description": description}
+
